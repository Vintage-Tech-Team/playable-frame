{
  "name": "estate-util-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "build": "npm run build -w @estate/formulas && npm run build -w api && npm run build -w web",
    "db:generate": "npm run prisma:generate -w api",
    "db:migrate": "npm run prisma:migrate -w api",
    "db:push": "npm run prisma:push -w api",
    "db:seed": "npm run prisma:seed -w api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
